APP_NAME=Weekend Agent
APP_ENV=local
LLM_PROVIDER=mock
LLM_API_KEY=
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen3.5-plus
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=2
LLM_TEMPERATURE=0.2
LLM_USE_STRUCTURED_OUTPUT=true
LLM_API_STYLE=chat_completions
LLM_TRUST_ENV=false
LLM_ALLOW_RULE_BASED_FALLBACK=false
OPENAI_API_KEY=
DATA_DIR=local_explorer_agent/app/data
DATA_BACKEND=json
DATABASE_URL=postgresql://user:password@localhost:5432/weekend_agent
